{
  "name": "sammium-portfolio-suite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/portfolio",
    "apps/quantumverse",
    "apps/research-lab",
    "apps/agrimind-ai",
    "apps/cosmos-os"
  ],
  "scripts": {
    "dev": "npm run dev:client -w @sammium/portfolio",
    "dev:portfolio": "npm run dev:client -w @sammium/portfolio",
    "dev:quantumverse": "npm run dev -w @sammium/quantumverse",
    "dev:research": "npm run dev -w @sammium/research-lab",
    "dev:agrimind": "npm run dev -w @sammium/agrimind-ai",
    "dev:cosmos": "npm run dev -w @sammium/cosmos-os",
    "lint": "npm run lint --workspaces --if-present",
    "build:projects": "npm run build:client -w @sammium/quantumverse && npm run build:client -w @sammium/research-lab && npm run build:client -w @sammium/agrimind-ai && npm run build:client -w @sammium/cosmos-os",
    "assemble": "node scripts/assemble-projects.mjs",
    "build:portfolio": "npm run build:client -w @sammium/portfolio",
    "build:pages": "npm run build:projects && npm run assemble && npm run build:portfolio",
    "preview": "npm run preview --workspace @sammium/portfolio --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}