# Server-only secret. Never prefix this with VITE_ and never commit a real key.
GEMINI_API_KEY=""

# Optional Gemini model override.
GEMINI_MODEL="gemini-3.5-flash"

# Express server port.
PORT=3000

# Optional public API origin used by the browser build.
# Leave empty when frontend and backend share the same origin.
# Example: VITE_API_BASE_URL="https://sentinel-api.example.com"
VITE_API_BASE_URL=""
